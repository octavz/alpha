{
  "name": "@alpha/backend",
  "version": "1.0.0",
  "description": "Alpha backend with Bun.js + Elysia + PostgreSQL",
  "main": "dist/index.js",
  "types": "src/types.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/scripts/seed-businesses.ts",
    "db:migrate": "bun run scripts/run-migration.ts",
    "db:test": "node scripts/simple-test.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@elysiajs/cors": "0.7.0",
    "@elysiajs/swagger": "0.7.0",
    "@faker-js/faker": "^10.3.0",
    "@sinclair/typebox": "0.32.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.30.10",
    "elysia": "1.0.0",
    "jsonwebtoken": "^9.0.2",
    "localtunnel": "^2.0.2",
    "postgres": "^3.4.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "bun-types": "latest",
    "drizzle-kit": "^0.22.8",
    "eslint": "^8.56.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "bun",
    "elysia",
    "postgresql",
    "drizzle",
    "api",
    "backend"
  ],
  "author": "Alpha Team",
  "license": "MIT"
}