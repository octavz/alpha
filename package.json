{
  "name": "alpha",
  "version": "1.0.0",
  "private": true,
  "description": "Alpha client-server application",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:web\"",
    "dev:backend": "cd packages/backend && bun run dev",
    "dev:web": "cd packages/web && bun run dev",
    "dev:mobile": "cd packages/mobile && bun run android",
    "build": "npm run build --workspaces",
    "build:backend": "cd packages/backend && bun run build",
    "build:web": "cd packages/web && bun run build",
    "test": "npm run test --workspaces",
    "test:backend": "cd packages/backend && bun run test",
    "test:web": "cd packages/web && bun run test",
    "lint": "npm run lint --workspaces",
    "docker:dev": "docker-compose up",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up",
    "docker:build": "docker-compose build",
    "k8s:deploy": "./scripts/deploy-k8s.sh",
    "db:migrate": "cd packages/backend && bun run db:migrate",
    "db:seed": "cd packages/backend && bun run db:seed",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/*/.next"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "keywords": [
    "alpha",
    "bun",
    "elysia",
    "react",
    "react-native",
    "typescript",
    "postgresql",
    "docker",
    "kubernetes"
  ],
  "author": "Alpha Team",
  "license": "MIT"
}